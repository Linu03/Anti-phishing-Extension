{
  "manifest_version": 3,
  "name": "Anti-Phishing Shield",
  "version": "0.1.0",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Anti-Phishing Shield"
  }
}
