# Copy to .env and adjust if needed:
#   cp .env.example .env
#
# Visual brand pHash runs offline — no API keys required for core detection.

# Optional: plain-English explanations via local Ollama (POST /v1/explain)
EXPLAIN_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
EXPLAIN_TIMEOUT_SEC=15
